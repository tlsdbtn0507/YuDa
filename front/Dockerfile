FROM node:alpine as builder

ARG WDS_SOCKET_PORT
ARG REACT_APP_SERVER
ARG REACT_APP_DELAY

ENV REACT_APP_SERVER=$REACT_APP_SERVER 
ENV WDS_SOCKET_PORT=$WDS_SOCKET_PORT
ENV REACT_APP_DELAY=$REACT_APP_DELAY

WORKDIR /app

COPY ./package.json ./

COPY ./package-lock.json ./

RUN npm install

COPY . .

EXPOSE 3000

CMD [ "npm" , "run", "start" ]
